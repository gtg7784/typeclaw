{
  "name": "typeclaw",
  "private": true,
  "bin": {
    "typeclaw": "src/cli/index.ts"
  },
  "files": [
    "src",
    "scripts",
    "typeclaw.schema.json"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "test": "bun test",
    "generate:schema": "bun run scripts/generate-schema.ts",
    "postinstall": "bun run scripts/generate-schema.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260416.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
